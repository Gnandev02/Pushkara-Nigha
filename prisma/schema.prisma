datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(cuid())
  name      String
  password  String
  email     String     @unique
  role      String     @default("operator") // admin, operator
  approved  Boolean    @default(false)
  createdAt DateTime   @default(now())
  loginLogs LoginLog[]
}

model LoginLog {
  id          String   @id @default(cuid())
  userId      String
  loginTime   DateTime @default(now())
  ipAddress   String?
  deviceInfo  String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Camera {
  id        String   @id @default(cuid())
  cameraId  String   @unique
  name      String
  location  String
  rtspUrl   String?
  status    String   @default("active") // active, inactive, warning, critical
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  analytics Analytics[]
  alerts    Alert[]
  videoBlob VideoBlob?
}

model Analytics {
  id             String   @id @default(cuid())
  cameraId       String
  totalPeople    Int
  uniquePeople   Int
  maleCount      Int
  femaleCount    Int
  unknownGender  Int
  density        Float
  riskScore      Float
  createdAt      DateTime @default(now())
  camera         Camera   @relation(fields: [cameraId], references: [cameraId], onDelete: Cascade)
}

model Alert {
  id          String   @id @default(cuid())
  cameraId    String
  message     String
  severity    String   // info, warning, critical
  timestamp   DateTime @default(now())
  resolved    Boolean  @default(false)
  camera      Camera   @relation(fields: [cameraId], references: [cameraId], onDelete: Cascade)
}

model GlobalState {
  id        String   @id @default("singleton")
  stateData Json
  updatedAt DateTime @updatedAt
}

model VideoBlob {
  id        String   @id @default(cuid())
  cameraId  String   @unique
  mimeType  String
  data      Bytes
  updatedAt DateTime @updatedAt
  camera    Camera   @relation(fields: [cameraId], references: [cameraId], onDelete: Cascade)
}
